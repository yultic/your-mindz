datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Appointment {
  id String @id @default(cuid())
  paypalOrderId String @unique  
  captureId String? @unique  // El resultado del pago. Único para evitar que un pago se use en dos citas. El "?" permite que existan muchos "null" (citas sin pagar aún).
  sessionType String @default("therapy-session")
  amount Decimal
  currency String @default("USD")
  status  String  @default("pending")
  payerEmail String?
  payerName String?
  paidAt DateTime?
  confirmedAt DateTime?
  calendlyToken String? @unique
  calendlyTokenUsedAt DateTime?
  createdAt DateTime? @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([calendlyToken])

}